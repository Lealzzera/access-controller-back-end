PORT=3000
NODE_ENV=production

# RDS PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@RDS_HOST:5432/DATABASE_NAME

# Auth
JWT_SECRET=change-me-to-a-long-random-secret

# CORS: use the exact Amplify frontend URL, without a trailing slash.
ACCESS_CONTROLLER_FRONT_END=https://your-amplify-domain.amplifyapp.com

# S3
AWS_REGION=sa-east-1
AWS_BUCKET_NAME=your-s3-bucket-name

# Prefer an ECS task role for S3 permissions in production.
# Keep these only for local development if you do not use an AWS profile.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
